    "lucide-react": "^1.17.0",
    "next": "16.2.9",
    "pino": "^9.14.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
