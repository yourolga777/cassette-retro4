# ──────────────────────────────────────
# База данных (Neon.tech — бесплатно)
# ──────────────────────────────────────
# Получить: https://neon.tech → создать проект → скопировать строку
DATABASE_URL=

# ──────────────────────────────────────
# Тинькофф Касса
# ──────────────────────────────────────
# Получить: https://kassa.tinkoff.ru → Настройки → Терминалы
# Для теста: в TINKOFF_TERMINAL_KEY укажите "TinkoffBankTest", PASSWORD оставьте пустым
TINKOFF_TERMINAL_KEY=
TINKOFF_PASSWORD=
TINKOFF_API_URL=https://securepay.tinkoff.ru/v2

# ──────────────────────────────────────
# Админка (придумайте свои)
# ──────────────────────────────────────
ADMIN_LOGIN=admin
ADMIN_PASSWORD=
# Любая длинная случайная строка для подписи JWT
ADMIN_SECRET=

# ──────────────────────────────────────
# Сайт
# ──────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ──────────────────────────────────────
# Telegram Bot (опционально)
# ──────────────────────────────────────
# Создать бота: https://t.me/BotFather
# Добавить бота в канал администратором
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=
TELEGRAM_CHANNEL_ID=
TELEGRAM_ERROR_CHANNEL_ID=
TELEGRAM_ADMIN_CHAT_ID=
